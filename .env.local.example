# --- Le Spot · variables d'environnement ---
# Copie ce fichier en `.env.local` et remplis-le avec les valeurs de TON projet Supabase.
# (Dans Supabase : Project Settings → API)

# URL de l'API de ton projet (publique).
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Clé "anon" (publique). Préfixe NEXT_PUBLIC_ => elle est envoyée AU NAVIGATEUR.
# C'est normal : elle est censée être protégée par la RLS (Row Level Security).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clé "service_role" (SECRÈTE). Pas de préfixe NEXT_PUBLIC_ => elle reste CÔTÉ SERVEUR.
# Ne JAMAIS l'exposer au navigateur ni la committer. (Non utilisée par l'app naïve,
# elle sert à illustrer la frontière des secrets en cours.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
